{
  "name": "svelte-bench",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "@cursor/sdk": "^1.0.23",
    "@google/genai": "^2.10.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "jsdom": "^29.1.1",
    "openai": "^6.45.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "vitest": "^3.2.6"
  },
  "scripts": {
    "start": "pnpm run-tests && pnpm build",
    "run-tests": "tsx ./index.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm merge && tsx ./build-static.ts",
    "build-v1": "tsx ./merge-v1.ts && tsx ./build-static.ts",
    "verify": "tsx ./verify.ts",
    "merge": "tsx ./merge.ts",
    "merge-v1": "tsx ./merge-v1.ts",
    "open": "node -e \"require('child_process').spawn('open', ['benchmarks/benchmark-results-merged.html'], { stdio: 'inherit' })\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@testing-library/jest-dom": "^6.9.1",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "ollama": "^0.6.3",
    "rimraf": "^6.1.3",
    "svelte": "^5.56.4",
    "tsx": "^4.23.0",
    "undici": "^8.7.0",
    "vite": "^8.1.4"
  }
}
